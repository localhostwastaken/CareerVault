# ── CareerVault server config ────────────────────────────────────────────────
# Copy to .env and fill in. Validated at startup by ConfigModule (Joi) — fail-fast.

# Core
NODE_ENV=development
PORT=9900
CORS_ORIGIN=http://localhost:5173
WORKER=false                       # true on the instance that runs cron/queue jobs

# Database — local PostgreSQL with the pgvector extension enabled:
#   createdb careervault && psql -d careervault -c "CREATE EXTENSION IF NOT EXISTS vector;"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/careervault?schema=public"

# JWT (RS256). Generate a keypair, then PEM-encode as single-line with \n escapes.
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Document signing master key — wraps per-org RSA private keys at rest (LocalKms).
# 32-byte base64 key:  openssl rand -base64 32
KMS_MASTER_KEY=

# Adapter selection: "local" (default, no cloud) or "real"
KEY_MANAGEMENT_DRIVER=local        # local | aws
BLOCKCHAIN_DRIVER=local            # local | amoy
PAYMENT_DRIVER=mock                # mock | stripe
EMAIL_DRIVER=console               # console | gmail | ses

# Gmail SMTP (only when EMAIL_DRIVER=gmail — free, no domain/CC needed)
# 1. Enable 2FA on the Google account at https://myaccount.google.com/security
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
#    (select "Other (Custom name)" → "CareerVault")
# 3. Paste the 16-char password below (spaces are ignored by Gmail)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=
STORAGE_DRIVER=local               # local | s3

# Redis (used when adapters are real; dev falls back to in-memory)
REDIS_URL=redis://localhost:6379

# AI service (FastAPI)
AI_SERVICE_URL=http://localhost:9910
AI_SERVICE_SECRET=                 # shared secret; leave blank in local dev

# Blockchain (only when BLOCKCHAIN_DRIVER=amoy)
POLYGON_RPC_URL=
ANCHOR_REGISTRY_ADDRESS=
ANCHOR_PRIVATE_KEY=

# Stripe (only when PAYMENT_DRIVER=stripe — use test-mode keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Local storage (when STORAGE_DRIVER=local)
STORAGE_LOCAL_DIR=./storage
