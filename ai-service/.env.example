PORT=9910

# Skill extraction via Groq (groq.com) — OpenAI-compatible, generous free tier.
# Leave GROQ_API_KEY empty to use the built-in heuristic extractor instead.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
